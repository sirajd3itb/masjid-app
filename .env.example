APP_NAME="Masjid Al-Ikhlas"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://USERNAME.alwaysdata.net

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── Database ─────────────────────────────────────────────────────
# Gunakan SQLite (filesystem persisten di alwaysdata)
DB_CONNECTION=sqlite
# DB_DATABASE otomatis pakai /database/database.sqlite

# Atau pakai MySQL jika ingin (isi dari alwaysdata admin panel):
# DB_CONNECTION=mysql
# DB_HOST=mysql-USERNAME.alwaysdata.net
# DB_PORT=3306
# DB_DATABASE=USERNAME_masjid
# DB_USERNAME=USERNAME
# DB_PASSWORD=

# ─── Session & Cache (file = hemat RAM) ──────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ─── Admin credentials (set saat pertama deploy) ─────────────────
ADMIN_NAME="Administrator"
ADMIN_EMAIL=admin@masjidalIkhlas.com
ADMIN_PASSWORD=ganti_password_anda_di_sini

# ─── Mail ────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@masjidalIkhlas.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
